# ── Neo4j ──────────────────────────────────────────────────────────────────
# В docker compose хост берётся из docker-compose.yml (bolt://neo4j:7687).
# Для локального запуска без Docker — localhost.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=task2password

# ── AI-модели (RouterAI · routerai.ru — российский роутер, санкц-чистый) ─────
# ОБЯЗАТЕЛЬНО: вставьте свой ключ RouterAI (нужен для семантики/VL/верификации).
LLM_PROVIDER=routerai
ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1

# ── Авторизация ─────────────────────────────────────────────────────────────
# Смените секрет в проде; пароль стартового администратора (логин admin).
JWT_SECRET=change-me-in-prod
ADMIN_PASSWORD=admin123

# Путь к исходному корпусу (только для повторного извлечения; в проде не нужен).
# CORPUS_DIR=/absolute/path/to/corpus
